✅ 3) Sum Array + Largest Element
App.java
package com.example;

public class App {

    public int sumArray(int[] arr) {
        int sum = 0;
        for (int num : arr) {
            sum += num;
        }
        return sum;
    }

    public int findLargest(int[] arr) {
        int max = arr[0];
        for (int num : arr) {
            if (num > max) {
                max = num;
            }
        }
        return max;
    }

    public static void main(String[] args) {
        App obj = new App();
        int[] arr = {10, 25, 5, 40};

        System.out.println("Sum: " + obj.sumArray(arr));
        System.out.println("Largest: " + obj.findLargest(arr));
    }
}
