✅ 2) Reverse Number + Count Digits
App.java
package com.example;

public class App {

    public int reverse(int num) {
        int rev = 0;

        while (num != 0) {
            rev = rev * 10 + num % 10;
            num /= 10;
        }
        return rev;
    }

    public int countDigits(int num) {
        int count = 0;

        while (num != 0) {
            count++;
            num /= 10;
        }
        return count;
    }

    public static void main(String[] args) {
        App obj = new App();
        int num = 12345;

        System.out.println("Reversed: " + obj.reverse(num));
        System.out.println("Digits: " + obj.countDigits(num));
    }
}
