✅ 2) Addition & Reverse Digits
App.java
package com.example;

public class App {

    public int add(int a, int b) {
        return a + b;
    }

    public int reverse(int num) {
        int rev = 0;
        while (num != 0) {
            rev = rev * 10 + num % 10;
            num /= 10;
        }
        return rev;
    }

    public static void main(String[] args) {
        App obj = new App();

        int a = 123, b = 45;
        int sum = obj.add(a, b);

        System.out.println("Sum: " + sum);
        System.out.println("Reversed Sum: " + obj.reverse(sum));
    }
}
