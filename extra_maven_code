# 3) Employee Salary Calculator

## App.java

```java
package com.example;

public class App {

    public double calculateHRA(double basic) {
        return basic * 0.20;
    }

    public double calculateDA(double basic) {
        return basic * 0.10;
    }

    public double calculateGrossSalary(double basic) {
        return basic + calculateHRA(basic) + calculateDA(basic);
    }

    public double calculateTax(double grossSalary) {
        return grossSalary * 0.05;
    }

    public double calculateNetSalary(double basic) {
        double gross = calculateGrossSalary(basic);
        double tax = calculateTax(gross);
        return gross - tax;
    }

    public static void main(String[] args) {
        App employee = new App();

        double basic = 20000;
        double hra = employee.calculateHRA(basic);
        double da = employee.calculateDA(basic);
        double gross = employee.calculateGrossSalary(basic);
        double tax = employee.calculateTax(gross);
        double net = employee.calculateNetSalary(basic);

        System.out.println("Basic Salary: " + basic);
        System.out.println("HRA: " + hra);
        System.out.println("DA: " + da);
        System.out.println("Gross Salary: " + gross);
        System.out.println("Tax: " + tax);
        System.out.println("Net Salary: " + net);
    }
}
```

