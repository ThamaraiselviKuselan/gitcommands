# Block World using Goal Stack Planning 
 
class State: 
    def __init__(self): 
        self.on = {}       # on[X] = Y means X is on Y 
        self.clear = set() # blocks with nothing on top 
        self.holding = None 
        self.arm_empty = True 
 
    def copy(self): 
        new = State() 
        new.on = self.on.copy() 
        new.clear = self.clear.copy() 
        new.holding = self.holding 
        new.arm_empty = self.arm_empty 
        return new 
 
# Actions 
def pickup(state, x): 
    if state.arm_empty and x in state.clear and state.on[x] == 
'table': 
        state.holding = x 
        state.arm_empty = False 
        state.clear.remove(x) 
        state.on[x] = None 
        print(f"Action: PICKUP({x})") 
        return True 
    return False 
 
def putdown(state, x): 
    if state.holding == x: 
        state.on[x] = 'table' 
        state.clear.add(x) 
        state.holding = None 
        state.arm_empty = True 
        print(f"Action: PUTDOWN({x})") 
        return True 
    return False 
 
def stack(state, x, y): 
    if state.holding == x and y in state.clear: 
        state.on[x] = y 
        state.clear.add(x) 
        state.clear.remove(y) 
        state.holding = None 
        state.arm_empty = True 
        print(f"Action: STACK({x}, {y})") 
        return True 
    return False 
 
def unstack(state, x, y): 
    if state.arm_empty and state.on[x] == y and x in state.clear: 
        state.holding = x 
        state.arm_empty = False 
        state.clear.add(y) 
        state.clear.remove(x) 
        state.on[x] = None 
        print(f"Action: UNSTACK({x}, {y})") 
        return True 
    return False 
 
# Planning function (simple goal matching) 
def solve(initial, goal): 
    state = initial.copy() 
 
    print("\n--- Planning Steps ---") 
 
    # Step 1: Clear everything to table 
    for x in list(state.on.keys()): 
        if state.on[x] != 'table': 
            y = state.on[x] 
            if x in state.clear: 
                unstack(state, x, y) 
                putdown(state, x) 
 
    # Step 2: Achieve goal stacking 
    for x in goal.on: 
        if goal.on[x] != 'table': 
            y = goal.on[x] 
 
            if state.on[x] == 'table': 
                pickup(state, x) 
                stack(state, x, y) 
 
    print("\n--- Final State ---") 
    print(state.on) 
 
# MAIN 
def main(): 
    print("=== Block World Problem ===") 
 
    initial = State() 
    goal = State() 
 
    blocks = input("Enter blocks (space separated, e.g. A B C): 
").split() 
 
    print("\nEnter Initial State:") 
    for b in blocks: 
        loc = input(f"{b} is on (block/table): ") 
        initial.on[b] = loc 
 
    # Set clear blocks 
    initial.clear = set(blocks) 
    for b in blocks: 
        if initial.on[b] != 'table': 
            if initial.on[b] in initial.clear: 
                initial.clear.remove(initial.on[b]) 
 
    print("\nEnter Goal State:") 
    for b in blocks: 
        loc = input(f"{b} should be on (block/table): ") 
        goal.on[b] = loc 
 
    goal.clear = set(blocks) 
 
    solve(initial, goal) 
 
