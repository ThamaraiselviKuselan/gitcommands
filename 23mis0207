import heapq

def greedy_bfs(graph, heuristic, start, goal):
    pq = [(heuristic[start], start)]
    visited = set()
    step = 1

    print("\n--- Greedy BFS Step-by-Step ---")

    while pq:
        print(f"\nStep {step}:")
        print("Priority Queue:", pq)

        h, node = heapq.heappop(pq)

        if node in visited:
            continue

        print(f"Selected Node: {node} with h(n) = {h}")
        visited.add(node)
        print("Visited:", visited)

        if node == goal:
            print("\n✅ Goal Reached!")
            return

        for neighbour in graph[node]:
            if neighbour not in visited:
                print(f"  Adding {neighbour} with h(n) = {heuristic[neighbour]}")
                heapq.heappush(pq, (heuristic[neighbour], neighbour))

        step += 1

    print("No path found")

