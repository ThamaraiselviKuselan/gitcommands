from collections import deque

def get_adjacent(x, y, n):
    neighbors = []
    for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
        nx, ny = x + dx, y + dy
        if 1 <= nx <= n and 1 <= ny <= n:
            neighbors.append((nx, ny))
    return neighbors

def solve_wumpus():
    print("=" * 50)
    print("    WUMPUS WORLD — Propositional Logic")
    print("=" * 50)

    n = int(input("Enter grid size N (e.g. 4 for 4x4): "))

    def parse_pos(prompt):
        while True:
            try:
                raw = input(prompt).strip()
                x, y = map(int, raw.split(","))
                if 1 <= x <= n and 1 <= y <= n:
                    return (x, y)
                print(f"  Position must be within 1–{n}. Try again.")
            except:
                print("  Enter as x,y (e.g. 3,2)")

    wumpus = parse_pos("Wumpus position (x,y), not (1,1): ")
    gold = parse_pos("Gold position (x,y): ")
    num_pits = int(input("Number of pits: "))

    pits = set()
    for i in range(num_pits):
        pit = parse_pos(f"  Pit {i+1} position (x,y), not (1,1): ")
        pits.add(pit)

    agent = (1, 1)
    visited = set()
    safe = set()
    visited.add(agent)
    safe.add(agent)

    score = 0
    step = 0

    def get_percepts(pos):
        adj = get_adjacent(pos[0], pos[1], n)
        stench = wumpus in adj
        breeze = any(p in pits for p in adj)
        glitter = (pos == gold)
        return stench, breeze, glitter

    def mark_safe(pos, stench, breeze):
        adj = get_adjacent(pos[0], pos[1], n)
        if not stench and not breeze:
            for cell in adj:
                safe.add(cell)

    def find_next_safe():
        for cell in sorted(safe):
            if cell not in visited:
                return cell
        return None

    print("\n--- SIMULATION START ---")
    print(f"Agent starts at (1,1). Goal: Grab Gold at {gold} and return.\n")

    while True:
        step += 1
        score -= 1

        stench, breeze, glitter = get_percepts(agent)

        print(f"Step {step}: Agent at {agent}")
        percepts = []
        if stench:
            percepts.append("Stench")
        if breeze:
            percepts.append("Breeze")
        if glitter:
            percepts.append("Glitter ✨")
        print(f"  Percepts: {', '.join(percepts) if percepts else 'None'}")

        mark_safe(agent, stench, breeze)
        print(f"  Known safe: {sorted(safe)}")

        if glitter:
            score += 1000
            print("  ACTION: GRAB GOLD! Score += 1000")
            print("\n✅ SUCCESS! Agent grabbed the gold!")
            print(f"   Final Score: {score}")
            return

        next_cell = find_next_safe()

        if next_cell is None:
            adj = get_adjacent(agent[0], agent[1], n)
            moved = False
            for cell in adj:
                if cell not in visited:
                    next_cell = cell
                    moved = True
                    break
            if not moved:
                print("\n  No safe unvisited cell reachable. Agent gives up.")
                print(f"   Final Score: {score}")
                return

        print(f"  ACTION: MOVE to {next_cell}")
        agent = next_cell
        visited.add(agent)
        safe.add(agent)

        if agent in pits:
            score -= 1000
            print(f"\n Agent fell into a Pit at {agent}! Game Over.")
