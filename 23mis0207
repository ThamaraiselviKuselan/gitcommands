def dls(graph, node, goal, depth, path):
    print(f"Visiting: {node}, Depth left: {depth}")

    if depth == 0 and node == goal:
        return path + [node]

    if depth > 0:
        for neighbour in graph[node]:
            result = dls(graph, neighbour, goal, depth - 1, path + [node])
            if result:
                return result

    return None


def ids(graph, start, goal, max_depth):
    print("\n--- IDS Step-by-Step ---")

    for depth in range(max_depth + 1):
        print(f"\nDepth Limit = {depth}")
        result = dls(graph, start, goal, depth, [])

        if result:
            print("\nGoal Found!")
            print("Path:", " -> ".join(result))
            print("Depth:", depth)
            return

    print("Goal not found")


