import heapq

def ucs_with_path(graph, start, goal):
    pq = [(0, start, [start])]
    visited = set()
    step = 1

    print("\n--- UCS Step-by-Step ---")

    while pq:
        print(f"\nStep {step}:")
        print("Priority Queue:", pq)

        cost, node, path = heapq.heappop(pq)
        print(f"Selected Node: {node} with cost {cost}")
        print("Path so far:", " -> ".join(path))

        if node == goal:
            print("\n✅ Goal Reached!")
            print("Final Path:", " -> ".join(path))
            print("Minimum Cost:", cost)
            return

        if node not in visited:
            visited.add(node)
            print("Visited:", visited)

            for neighbour, weight in graph[node]:
                if neighbour not in visited:
                    new_cost = cost + weight
                    print(f"  Adding {neighbour} with cost {new_cost}")
                    heapq.heappush(
                        pq,
                        (new_cost, neighbour, path + [neighbour])
                    )

        step += 1

    print("No path found")

