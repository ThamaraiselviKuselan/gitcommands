import heapq
def heuristic(state, target):
    return abs(state[0]-target) + abs(state[1]-target)

def a_star(cap_a, cap_b, target):
    start=(0, 0)  # initial state (0 liters in both jugs)
    pq=[]
    heapq.heappush(pq,(0+heuristic(start, target),0, start, []))  
    visited=set()
    while pq:
        f,g,state,path=heapq.heappop(pq)
        if state in visited:
            continue
        visited.add(state)
        path=path+[state]
        if target in state:
            return path
        x,y=state
        successors=[(cap_a,y),(x,cap_b),(0,y),(x,0),(min(x+cap_b-y,cap_a),min(y+cap_a-x,cap_b))]
        for s in successors:
            if s not in visited:
                heapq.heappush(pq,(g+1+heuristic(s,target),g+1,s,path))
    return None
