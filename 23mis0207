# Pure Python Bayesian Network (No external libraries) 
 
# Function to get valid probabilities 
def get_probs(prompt, n): 
    while True: 
        try: 
            vals = list(map(float, input(prompt).split())) 
            if len(vals) != n: 
                print(f"Enter exactly {n} values.") 
                continue 
            if any(v < 0 or v > 1 for v in vals): 
                print("Values must be between 0 and 1.") 
                continue 
            return vals 
        except: 
            print("Invalid input!") 
 
# Joint Probability Calculation 
def joint_prob(c, s, r, w, P_C, P_S_C, P_R_C, P_W_SR): 
    p_c = P_C[c] 
    p_s = P_S_C[c][s] 
    p_r = P_R_C[c][r] 
    p_w = P_W_SR[s][r][w] 
    return p_c * p_s * p_r * p_w 
 
# Marginal / Conditional using enumeration 
def query(query_var, evidence, P_C, P_S_C, P_R_C, P_W_SR): 
    vars_list = ['C', 'S', 'R', 'W'] 
    total = [0, 0] 
 
    # iterate all combinations (2^4 = 16) 
    for c in [0,1]: 
        for s in [0,1]: 
            for r in [0,1]: 
                for w in [0,1]: 
                    assignment = {'C':c,'S':s,'R':r,'W':w} 
 
                    # check evidence match 
                    valid = True 
                    for ev in evidence: 
                        if assignment[ev] != evidence[ev]: 
                            valid = False 
                            break 
                    if not valid: 
                        continue 
 
                    jp = joint_prob(c, s, r, w, P_C, P_S_C, P_R_C, 
P_W_SR) 
 
                    total[assignment[query_var]] += jp 
 
    # normalize 
    s = total[0] + total[1] 
    if s == 0: 
        return [0,0] 
    return [total[0]/s, total[1]/s] 
 
def main(): 
    print("\n=== Bayesian Network (Pure Python) ===") 
 
    # Input probabilities 
    P_C = get_probs("Enter P(C=0) P(C=1): ", 2) 
 
    s_vals = get_probs("Enter P(S=1|C=0) P(S=1|C=1): ", 2) 
    P_S_C = [[1 - s_vals[0], s_vals[0]], 
             [1 - s_vals[1], s_vals[1]]] 
 
    r_vals = get_probs("Enter P(R=1|C=0) P(R=1|C=1): ", 2) 
    P_R_C = [[1 - r_vals[0], r_vals[0]], 
             [1 - r_vals[1], r_vals[1]]] 
 
    w_vals = get_probs("Enter P(W=1|S,R) for 00 01 10 11: ", 4) 
 
    # Convert to 3D table 
    P_W_SR = [ 
        [[1 - w_vals[0], w_vals[0]], [1 - w_vals[1], w_vals[1]]], 
        [[1 - w_vals[2], w_vals[2]], [1 - w_vals[3], w_vals[3]]] 
    ] 
 
    while True: 
        print("\nVariables: C (Cloudy), S (Sprinkler), R (Rain), W 
(WetGrass)") 
